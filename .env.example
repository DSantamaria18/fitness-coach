# Copia este fichero a .env y rellena los valores reales.
# Nunca commitees .env — está en .gitignore.

# Ruta de la base de datos SQLite.
DATABASE_URL="file:./dev.db"

# Clave para firmar la cookie de sesión (Auth.js). Genera una con:
# npx auth secret
AUTH_SECRET=

# Credenciales del único usuario de la app. ADMIN_PASSWORD_HASH se genera
# con `npm run hash-password -- "tu-password"` — nunca guardes el password
# en claro aquí.
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# Clave de API de pago de Anthropic (Claude). Se usa para las propuestas de
# sesión con IA en /sesion y comentarios de progreso con IA en /informe.
# Obtén la clave en console.anthropic.com. En producción se configura como
# variable de entorno de Vercel (Environment Variables, scope Production),
# nunca en el propio .env.
ANTHROPIC_API_KEY=

# Se rellenará en una fase posterior del roadmap (servidor MCP):
# MCP_BEARER_TOKEN=

# --- Despliegue en Vercel + Turso (ver SPEC.md §8-11 y DECISIONS.md) ---
# Las credenciales de Turso (TURSO_DATABASE_URL / TURSO_AUTH_TOKEN) las
# documenta el adapter de Prisma para Turso; no las dupliques aquí.
#
# IMPORTANTE (guardrail de preview): en el dashboard de Vercel, las
# credenciales de la Turso de PRODUCCIÓN se configuran con scope "Production"
# únicamente. Los preview deployments (uno por PR) NO deben recibirlas, para
# que nunca escriban en la base de datos real (ver DECISIONS.md 2026-07-20,
# checklist de pasos manuales de fase 2).
#
# VERCEL_ENV lo inyecta Vercel automáticamente en cada deployment
# ("production" | "preview" | "development"). No lo pongas aquí ni lo definas
# a mano: es la señal que permite al código distinguir el entorno.
