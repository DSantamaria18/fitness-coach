// Esquema de dominio — ver SPEC.md §3 para la definición funcional.
// Cambios aquí deben reflejarse en SPEC.md/ARCHITECTURE.md si alteran el contrato.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Single-user en el MVP (SPEC §2), pero modelado como tabla para no acoplar
// el login a una fila implícita y dejar la puerta abierta a auditar sesiones.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  bodyWeights        BodyWeight[]
  sessions           Session[]
  backups            Backup[]
  comentarioProgreso ComentarioProgreso?
}

model BodyWeight {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weightKg  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

enum ExerciseType {
  STRENGTH
  CARDIO
}

// Catálogo cerrado (SPEC §3): sembrado por seed script, no editable desde
// el registro de una sesión.
model Exercise {
  id        String       @id @default(cuid())
  name      String       @unique
  type      ExerciseType
  createdAt DateTime     @default(now())

  strengthEntries StrengthEntry[]
  cardioEntries   CardioEntry[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  strengthEntries StrengthEntry[]
  cardioEntries   CardioEntry[]

  @@index([userId, date])
}

// Un StrengthEntry agrupa las series de un ejercicio de fuerza dentro de
// una sesión (una sesión puede tener varios ejercicios de fuerza).
model StrengthEntry {
  id         String  @id @default(cuid())
  sessionId  String
  exerciseId String
  notes      String?
  order      Int

  session  Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise      @relation(fields: [exerciseId], references: [id])
  sets     StrengthSet[]

  @@index([sessionId])
  @@index([exerciseId])
}

model StrengthSet {
  id              String  @id @default(cuid())
  strengthEntryId String
  order           Int
  reps            Int
  weightKg        Float
  tempo           String?
  rpe             Int?

  strengthEntry StrengthEntry @relation(fields: [strengthEntryId], references: [id], onDelete: Cascade)

  @@index([strengthEntryId])
}

// Todos los campos numéricos son opcionales individualmente (SPEC §3: no
// todos los relojes miden todo).
model CardioEntry {
  id              String  @id @default(cuid())
  sessionId       String
  exerciseId      String
  // Posición dentro de la lista de ejercicios ORIGINAL de la sesión (misma
  // semántica que StrengthEntry.order), no dentro de la sublista de cardio:
  // permite reconstruir el orden intercalado real de fuerza/cardio (BL-004,
  // ver DECISIONS.md 2026-07-19). @default(0) para no romper filas ya
  // existentes al aplicar la migración (no destructiva).
  order           Int     @default(0)
  durationSeconds Int?
  distanceKm      Float?
  avgSpeedKmh     Float?
  avgPaceSecPerKm Int?
  avgHeartRate    Int?
  maxHeartRate    Int?
  steps           Int?
  stepFrequency   Float?
  kcal            Int?
  rpe             Int?
  notes           String?

  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
}

// Registra cuándo se descargó un backup manual (SPEC §11): no guarda el
// fichero en sí (se sirve y se descarta al vuelo), solo la fecha, para poder
// avisar en /ajustes si han pasado más de 30 días sin uno.
model Backup {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Comentario de progreso generado por IA a partir de get_progress_report
// (SPEC.md §14, punto 2). Fila única por usuario (userId @unique): cada
// generación sobrescribe la anterior, no hay histórico (decisión de
// producto — ver DECISIONS.md 2026-07-19).
model ComentarioProgreso {
  id         String   @id @default(cuid())
  userId     String   @unique
  texto      String
  generadoEn DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
